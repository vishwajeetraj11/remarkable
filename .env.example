# Copy to .env and fill in. All values are optional — features stay dormant
# without them. Every var is NEXT_PUBLIC_* (client-side, not secret).

# Canonical base URL used in metadata/sitemap (defaults to production domain).
NEXT_PUBLIC_SITE_URL=https://remarkable.vishwajeet.co

# Microsoft Clarity analytics. Off when empty.
NEXT_PUBLIC_CLARITY_ID=

# PostHog product analytics (Project token, phc_...). Off when empty.
NEXT_PUBLIC_POSTHOG_KEY=
# Only set for EU-region projects; defaults to https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Ads conversion tag (consent-gated behind the cookie banner).
# Without an ID the banner and tag never render.
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
